{
  "type": "module",
  "scripts": {
    "start": "tsx server.ts",
    "dev": "tsx --watch --watch-preserve-output server.ts",
    "start-coverage": "c8 --reporter=text --reporter=html tsx server.ts",
    "test": "vitest run",
    "tsc": "tsc --project tsconfig.json",
    "lint": "eslint",
    "lint-fix": "eslint --fix"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "morgan": "^1.11.0",
    "tsx": "^4.22.3",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.13.2",
    "@vitest/eslint-plugin": "^1.6.18",
    "c8": "^11.0.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "sync-request-curl": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "allowScripts": {
    "node-libcurl@5.0.2": true,
    "esbuild@0.28.1": true
  }
}
